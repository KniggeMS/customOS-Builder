<#
.SYNOPSIS
    customOS-Builder - Modular Windows 11 Optimierungs-Framework
    Version: 0.1
#>

param(
    [string]$Profile = "Minimal"
)

Write-Host "=== customOS-Builder wird gestartet ===" -ForegroundColor Cyan

# Administrator-Check
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Host "Bitte als Administrator ausführen!" -ForegroundColor Red
    exit 1
}

Write-Host "Profil '$Profile' wird geladen..." -ForegroundColor Green

# Basis-Funktionen
function Test-Internet {
    return (Test-Connection -ComputerName 8.8.8.8 -Count 1 -Quiet)
}

# TODO: Module laden (später erweitern)
Write-Host "Grundlegende System-Informationen..." -ForegroundColor Yellow
Get-ComputerInfo | Select-Object WindowsVersion, WindowsBuildLabEx | Format-List

Write-Host "`nNächste Schritte werden vorbereitet..." -ForegroundColor Green

# Hier kommen später die echten Module

Write-Host "`n=== customOS Setup abgeschlossen! ===" -ForegroundColor Cyan
Write-Host "Viel Spaß mit deinem optimierten System!" -ForegroundColor Magenta